[run]
source =
    backend/accounts
    backend/cart
    backend/contact
    backend/core
    backend/orders
    backend/pages
    backend/payments
    backend/products
    backend/reviews
    backend/services
    backend/utils
    backend/wallets
    backend/wishlist
branch = true
relative_files = true
omit =
    */migrations/*
    */tests.py
    */test_*.py
    admin_tests.py
    manage.py
    api/wsgi.py
    api/asgi.py
    .venv/*

[report]
precision = 2
show_missing = true

[xml]
output = coverage.xml