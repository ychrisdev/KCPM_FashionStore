[run]
source = .
branch = true
omit =
    orders/management/seed_ecommerce.py
    orders/management/audit_order_schema.py
    products/management/*
    */migrations/*
    accounts/birthday_reminder.py
    accounts/generate_birthday_voucher.py
    accounts/management/*
    */tests.py
    */test_*.py
    admin_tests.py
    manage.py
    api/wsgi.py
    api/asgi.py
    .venv/*

[report]
precision = 2
show_missing = true

[xml]
output = coverage.xml